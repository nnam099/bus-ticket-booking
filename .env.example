# ========================
# DATABASE
# ========================
DB_NAME=bus_ticket
DB_USER=postgres
DB_PASSWORD=postgres123
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/bus_ticket

# ========================
# REDIS
# ========================
REDIS_URL=redis://localhost:6379

# ========================
# JWT
# ========================
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ========================
# SERVER
# ========================
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:5173

# ========================
# OTP (SMS/Email)
# ========================
OTP_EXPIRE_MINUTES=5
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# ========================
# EMAIL (SMTP)
# ========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@busticket.vn

# ========================
# PAYMENT GATEWAYS
# ========================
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5173/payment/callback

MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create

# ========================
# BOOKING LOCK
# ========================
BOOKING_LOCK_MINUTES=15
MAX_SEATS_PER_BOOKING=5

# ========================
# FRONTEND
# ========================
VITE_API_URL=http://localhost:3000/api
VITE_SOCKET_URL=http://localhost:3000
